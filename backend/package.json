{
  "name": "@agentic-kanban/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "demo": "tsx watch src/index.ts --demo",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "reset-admin-password": "tsx src/scripts/reset-admin-password.ts"
  },
  "dependencies": {
    "@agentic-kanban/shared": "*",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "10.1.0",
    "@fastify/static": "9.1.3",
    "@fastify/swagger": "9.7.0",
    "@scalar/fastify-api-reference": "1.57.2",
    "drizzle-orm": "1.0.0-rc.4-5d5b77c",
    "fastify": "5.8.5",
    "pino-pretty": "13.1.3",
    "uuid": "11.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/uuid": "10.0.0",
    "drizzle-kit": "0.30.6",
    "tsx": "4.22.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  }
}
